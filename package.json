{
  "name": "ressio",
  "version": "1.0.0",
  "description": "Ressio — Lecteur RSS universel",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.ressio.app",
    "productName": "Ressio",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "keywords": [
    "cybersecurity",
    "rss",
    "monitoring"
  ],
  "author": "CyberWatch",
  "license": "MIT"
}
